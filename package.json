{
  "name": "n8n-nodes-dominusnode",
  "version": "1.2.1",
  "description": "n8n community nodes for Dominus Node rotating proxy service (53 tools across 7 nodes)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/DominusNodeApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/DominusNodeProxy/DominusNodeProxy.node.js",
      "dist/nodes/DominusNodeWallet/DominusNodeWallet.node.js",
      "dist/nodes/DominusNodeUsage/DominusNodeUsage.node.js",
      "dist/nodes/DominusNodeAccount/DominusNodeAccount.node.js",
      "dist/nodes/DominusNodeKeys/DominusNodeKeys.node.js",
      "dist/nodes/DominusNodePlans/DominusNodePlans.node.js",
      "dist/nodes/DominusNodeTeams/DominusNodeTeams.node.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "dominusnode",
    "proxy",
    "rotating-proxy",
    "web-scraping"
  ],
  "license": "MIT",
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "devDependencies": {
    "n8n-workflow": "^1.70.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  }
}
